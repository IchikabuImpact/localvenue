# =============================================================
# localvenue — .gitignore
# =============================================================

# ---------------- 機密情報 ----------------
# DB接続情報が入るため除外（config.sample.js は追跡対象）
config/config.js
.env
.env.*

# ---------------- 依存パッケージ ----------------
node_modules/

# ---------------- DBダンプ（公開リポジトリには含めない） ----------------
data/dumps/*
!data/dumps/.gitignore

# ---------------- ログ・一時ファイル ----------------
logs/
log/
tmp/
cache/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---------------- ランタイム ----------------
pids/
*.pid
*.pid.lock

# ---------------- テストカバレッジ ----------------
coverage/
*.lcov
.nyc_output/

# ---------------- Selenium / Chrome ----------------
chromedriver-linux64/
chromedriver-linux64.zip
.chrome-profile/
/tmp/chrome-profile-*/

# ---------------- ダウンロードパッケージ ----------------
*.deb
*.tgz

# ---------------- OS / IDE / ツール ----------------
.DS_Store
Thumbs.db
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.claude/

# =============================================================
# public/ は静的HTML配信のため git 管理対象とする
# （静的HTML配信用の生成物として管理）
# =============================================================
